{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Talon Pilot Studio",
  "version": "0.1.8",
  "identifier": "studio.talon.pilot.desktop",
  "build": {
    "frontendDist": "../../talon-pilot/web-next/dist",
    "devUrl": "http://127.0.0.1:5174"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Talon Pilot Studio",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' data: blob: https: http:",
        "font-src": "'self' data:",
        "connect-src": "'self' https: http: ws: wss: ipc: http://ipc.localhost",
        "worker-src": "'self' blob:",
        "frame-src": "'self' blob: https: http:",
        "media-src": "'self' blob: https: http:",
        "object-src": "'none'",
        "base-uri": "'self'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/darkmice/talon-pilot-studio/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ1NDMyRUQwMjVDNTNEMjYKUldRbVBjVWwwQzVEMWVaZmN3bjJnNDlvMlB1a25HaHBCZExpd2c0YUYremZpbjcwNDF3cmFOcGgK"
    }
  }
}
