{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Talon Pilot Studio",
  "version": "0.1.0",
  "identifier": "studio.talon.pilot.desktop",
  "build": {
    "frontendDist": "../../talon-pilot/web-next/dist",
    "devUrl": "http://127.0.0.1:5174"
  },
  "app": {
    "windows": [
      {
        "title": "Talon Pilot Studio",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
